{
  "productName": "Virel V2",
  "version": "2.5.0",
  "identifier": "com.nokrima.virel",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Virel V2",
        "width": 1216,
        "height": 820,
        "minWidth": 1216,
        "minHeight": 820,
        "maxWidth": 1216,
        "maxHeight": 820,
        "resizable": false,
        "maximizable": false,
        "transparent": false,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "windows": {
      "nsis": {
        "displayLanguageSelector": true,
        "languages": [
          "Turkish",
          "English"
        ],
        "installerHooks": "nsis/hooks.nsh"
      }
    },
    "active": true,
    "targets": "all",
    "externalBin": ["virel-core"],
    "resources": {
      "bin/vc_redist.x64.exe": "bin/vc_redist.x64.exe"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "",
      "endpoints": [
        "https://raw.githubusercontent.com/Nokrima/virel-updater/main/latest.json"
      ]
    }
  }
}
